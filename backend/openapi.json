{
    "openapi": "3.1.0",
    "info": {
        "title": "CRUD Users API",
        "version": "1.0.0",
        "description": "Simple CRUD API for managing users. All endpoints operate on the `/api/users` collection. PUT, PATCH and DELETE require the user `id` as a query parameter."
    },
    "servers": [
        {
            "url": "http://localhost:8000"
        }
    ],
    "tags": [
        {
            "name": "Users",
            "description": "User management operations"
        }
    ],
    "paths": {
        "/api/users": {
            "get": {
                "tags": ["Users"],
                "operationId": "listUsers",
                "summary": "List all users",
                "responses": {
                    "200": {
                        "description": "Users list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "users": {
                                            "type": "array",
                                            "items": { "$ref": "#/components/schemas/User" }
                                        }
                                    }
                                },
                                "example": {
                                    "users": [
                                        { "id": 1, "name": "Victor Raphael", "age": 24, "email": "victor@email.com" }
                                    ]
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalError"
                    }
                }
            },
            "post": {
                "tags": ["Users"],
                "operationId": "createUser",
                "summary": "Create a new user",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UserInput" },
                            "example": {
                                "name": "Victor Raphael",
                                "age": 24,
                                "email": "victor@email.com"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User created successfully",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/User" },
                                "example": {
                                    "id": 1,
                                    "name": "Victor Raphael",
                                    "age": 24,
                                    "email": "victor@email.com"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request — possible causes: invalid JSON body, missing required fields (`name`, `age`, `email`), or field validation errors (empty name, name over 100 chars, age not between 1–150, invalid email format)",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/Error" },
                                "examples": {
                                    "invalidJson": {
                                        "summary": "Invalid JSON body",
                                        "value": { "error": "Invalid JSON body" }
                                    },
                                    "missingFields": {
                                        "summary": "Missing required fields",
                                        "value": { "error": "name, age, email are required" }
                                    },
                                    "invalidAge": {
                                        "summary": "Validation error",
                                        "value": { "error": "Age must be between 1 and 150" }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalError"
                    }
                }
            },
            "put": {
                "tags": ["Users"],
                "operationId": "replaceUser",
                "summary": "Update a user (full replacement)",
                "parameters": [
                    { "$ref": "#/components/parameters/Id" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UserInput" },
                            "example": {
                                "name": "Victor Raphael",
                                "age": 25,
                                "email": "victor.new@email.com"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User updated successfully",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/User" }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request — possible causes: missing `id` query parameter, invalid JSON body, missing required fields (`name`, `age`, `email`), or field validation errors",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/Error" },
                                "examples": {
                                    "missingId": {
                                        "summary": "Missing id parameter",
                                        "value": { "error": "User id is required" }
                                    },
                                    "missingFields": {
                                        "summary": "Missing required fields",
                                        "value": { "error": "name, age, email are required" }
                                    },
                                    "invalidEmail": {
                                        "summary": "Validation error",
                                        "value": { "error": "Invalid email format" }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalError"
                    }
                }
            },
            "patch": {
                "tags": ["Users"],
                "operationId": "updateUser",
                "summary": "Partially update a user",
                "description": "Updates only the provided fields. At least one field (`name`, `age`, or `email`) should be sent.",
                "parameters": [
                    { "$ref": "#/components/parameters/Id" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UserPartial" },
                            "example": {
                                "age": 25
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User updated successfully",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/User" }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request — possible causes: missing `id` query parameter, invalid JSON body, or field validation errors (empty name, name over 100 chars, age not between 1–150, invalid email format)",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/Error" },
                                "examples": {
                                    "missingId": {
                                        "summary": "Missing id parameter",
                                        "value": { "error": "User id is required" }
                                    },
                                    "invalidJson": {
                                        "summary": "Invalid JSON body",
                                        "value": { "error": "Invalid JSON body" }
                                    },
                                    "invalidName": {
                                        "summary": "Validation error",
                                        "value": { "error": "Name cannot be empty" }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalError"
                    }
                }
            },
            "delete": {
                "tags": ["Users"],
                "operationId": "deleteUser",
                "summary": "Delete a user",
                "parameters": [
                    { "$ref": "#/components/parameters/Id" }
                ],
                "responses": {
                    "200": {
                        "description": "User deleted successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "deleted": { "$ref": "#/components/schemas/User" }
                                    }
                                },
                                "example": {
                                    "deleted": {
                                        "id": 1,
                                        "name": "Victor Raphael",
                                        "age": 24,
                                        "email": "victor@email.com"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Missing `id` query parameter",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/Error" },
                                "example": { "error": "User id is required" }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalError"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer", "example": 1, "readOnly": true },
                    "name": { "type": "string", "example": "Victor Raphael", "maxLength": 100 },
                    "age": { "type": "integer", "example": 24, "minimum": 1, "maximum": 150 },
                    "email": { "type": "string", "format": "email", "example": "victor@email.com" }
                },
                "required": ["id", "name", "age", "email"]
            },
            "UserInput": {
                "type": "object",
                "description": "Request body for creating or fully replacing a user",
                "required": ["name", "age", "email"],
                "properties": {
                    "name": { "type": "string", "maxLength": 100, "example": "Victor Raphael" },
                    "age": { "type": "integer", "minimum": 1, "maximum": 150, "example": 24 },
                    "email": { "type": "string", "format": "email", "example": "victor@email.com" }
                }
            },
            "UserPartial": {
                "type": "object",
                "description": "Request body for partially updating a user — all fields are optional",
                "properties": {
                    "name": { "type": "string", "maxLength": 100 },
                    "age": { "type": "integer", "minimum": 1, "maximum": 150 },
                    "email": { "type": "string", "format": "email" }
                }
            },
            "Error": {
                "type": "object",
                "properties": {
                    "error": { "type": "string", "example": "name, age, email are required" }
                },
                "required": ["error"]
            }
        },
        "parameters": {
            "Id": {
                "name": "id",
                "in": "query",
                "required": true,
                "schema": { "type": "integer" },
                "description": "Unique user ID",
                "example": 1
            }
        },
        "responses": {
            "UserNotFound": {
                "description": "User not found",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" },
                        "example": { "error": "User not found" }
                    }
                }
            },
            "InternalError": {
                "description": "Internal server error",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" },
                        "example": { "error": "Internal server error" }
                    }
                }
            }
        }
    }
}
